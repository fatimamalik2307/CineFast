<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cine"
                android:textColor="#E50914"
                android:textSize="26sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAST"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:textColor="#AAAAAA"
            android:layout_marginTop="14dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:id="@+id/btnToday"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:paddingHorizontal="16dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_date_selected">
                <View
                    android:id="@+id/dotToday"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_selected" />
                <TextView
                    android:id="@+id/txtToday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="6dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnTomorrow"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:paddingHorizontal="16dp"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_date_unselected">
                <View
                    android:id="@+id/dotTomorrow"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_unselected" />
                <TextView
                    android:id="@+id/txtTomorrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tomorrow"
                    android:textColor="#9CA3AF"
                    android:layout_marginStart="6dp"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Now Showing"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#1B2430"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="85dp"
                    android:layout_height="125dp"
                    android:src="@drawable/dark_knight"
                    android:scaleType="fitCenter" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:layout_gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Dark Knight"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Action • 152 min          Play"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBook1"
                            android:layout_width="100dp"
                            android:layout_height="38dp"
                            android:backgroundTint="#E50914"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingHorizontal="4dp"
                            android:text="Book Seats"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            app:cornerRadius="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTrailer1"
                            android:layout_width="95dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="10dp"
                            android:backgroundTint="#FFFFFF"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingHorizontal="4dp"
                            android:text="Trailer"
                            android:textColor="#000000"
                            android:textSize="11sp"
                            app:cornerRadius="16dp"
                            app:icon="@android:drawable/ic_media_play"
                            app:iconGravity="start"
                            app:iconPadding="4dp"
                            app:iconSize="16dp"
                            app:iconTint="#000000" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#1B2430"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="85dp"
                    android:layout_height="125dp"
                    android:src="@drawable/inception"
                    android:scaleType="fitCenter" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:layout_gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inception"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sci-Fi • 148 min      Play"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBook2"
                            android:layout_width="100dp"
                            android:layout_height="38dp"
                            android:text="Book Seats"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#E50914"
                            android:paddingHorizontal="4dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTrailer2"
                            android:layout_width="95dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="10dp"
                            android:text="Trailer"
                            app:icon="@android:drawable/ic_media_play"
                            app:iconTint="#000000"
                            app:iconSize="16dp"
                            app:iconPadding="4dp"
                            app:iconGravity="start"
                            android:textSize="11sp"
                            android:backgroundTint="#FFFFFF"
                            android:textColor="#000000"
                            android:paddingHorizontal="4dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#1B2430"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="85dp"
                    android:layout_height="125dp"
                    android:src="@drawable/interstellar"
                    android:scaleType="fitCenter" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:layout_gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Interstellar"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sci-Fi • 169 min      Play"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBook3"
                            android:layout_width="100dp"
                            android:layout_height="38dp"
                            android:text="Book Seats"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#E50914"
                            android:paddingHorizontal="4dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTrailer3"
                            android:layout_width="95dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="10dp"
                            android:text="Trailer"
                            app:icon="@android:drawable/ic_media_play"
                            app:iconTint="#000000"
                            app:iconSize="16dp"
                            app:iconPadding="4dp"
                            app:iconGravity="start"
                            android:textSize="11sp"
                            android:backgroundTint="#FFFFFF"
                            android:textColor="#000000"
                            android:paddingHorizontal="4dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#1B2430"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="85dp"
                    android:layout_height="125dp"
                    android:src="@drawable/shawshank"
                    android:scaleType="fitCenter" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:layout_gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Shawshank Redemption"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drama • 142 min       Play"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBook4"
                            android:layout_width="100dp"
                            android:layout_height="38dp"
                            android:text="Book Seats"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#E50914"
                            android:paddingHorizontal="4dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTrailer4"
                            android:layout_width="95dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="10dp"
                            android:text="Trailer"
                            app:icon="@android:drawable/ic_media_play"
                            app:iconTint="#000000"
                            app:iconSize="16dp"
                            app:iconPadding="4dp"
                            app:iconGravity="start"
                            android:textSize="11sp"
                            android:backgroundTint="#FFFFFF"
                            android:textColor="#000000"
                            android:paddingHorizontal="4dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
